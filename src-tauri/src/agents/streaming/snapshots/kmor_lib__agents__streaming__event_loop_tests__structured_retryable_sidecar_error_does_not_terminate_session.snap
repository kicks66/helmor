---
source: src/agents/streaming/event_loop_tests.rs
expression: entries
---
- event_type: turn/started
  emitted: []
  side_effects: []
- event_type: error
  emitted:
    - kind: Update
      messages:
        - role: system
          part_types:
            - system-notice
          streaming: ~
  side_effects: []
- event_type: item/agentMessage/delta
  emitted: []
  side_effects: []
- event_type: turn/completed
  emitted:
    - kind: Update
      messages:
        - role: system
          part_types:
            - system-notice
          streaming: ~
        - role: system
          part_types:
            - text
          streaming: ~
  side_effects: []
- event_type: end
  emitted:
    - kind: Update
      messages:
        - role: system
          part_types:
            - system-notice
          streaming: ~
        - role: system
          part_types:
            - text
          streaming: ~
    - kind: Done
      persisted: true
  side_effects: []
